{
  "expo": {
    "name": "Precio Luz",
    "slug": "PrecioLuz",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/LogoAppPrecioLuz.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0f0f1a"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.precioluz.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/LogoAppPrecioLuz.png",
        "backgroundColor": "#0f0f1a"
      },
      "package": "com.precioluz.app",
      "permissions": [
        "android.permission.INTERNET",
        "android.permission.ACCESS_NETWORK_STATE"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "extra": {
      "eas": {
        "projectId": "precio-luz-app"
      }
    }
  }
}
